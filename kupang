<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Layout Foto Studio A4 (3x4)</title>

<!-- Library Eksternal -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

<style>
    :root {
        --primary-color: #2563eb;
        --primary-hover: #1d4ed8;
        --bg-color: #f3f4f6;
        --border-color: #333;
        --paper-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: var(--bg-color);
        margin: 0;
        padding: 20px;
        color: #333;
        display: flex;
        flex-direction: column;
        align-items: center;
        min-height: 100vh;
    }

    /* --- Controls Area --- */
    .controls {
        background: white;
        padding: 20px;
        border-radius: 12px;
        box-shadow: var(--paper-shadow);
        margin-bottom: 30px;
        width: 100%;
        max-width: 800px;
        box-sizing: border-box;
        text-align: center;
    }

    .controls h1 {
        margin-top: 0;
        font-size: 1.5rem;
        color: #1f2937;
    }

    .input-group {
        display: flex;
        gap: 10px;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 15px;
    }

    input[type="file"] {
        padding: 10px;
        border: 1px solid #d1d5db;
        border-radius: 6px;
        background: #f9fafb;
        cursor: pointer;
    }

    button {
        padding: 10px 20px;
        background-color: var(--primary-color);
        color: white;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    button:hover {
        background-color: var(--primary-hover);
    }

    button:disabled {
        background-color: #9ca3af;
        cursor: not-allowed;
    }

    /* --- Preview Area --- */
    #preview {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 30px;
        width: 100%;
        padding-bottom: 50px;
    }

    .empty-state {
        color: #6b7280;
        margin-top: 50px;
        font-style: italic;
    }

    /* --- A4 Page Setup --- */
    .page {
        width: 21cm;
        height: 29.7cm;
        background: white;
        /* Pastikan margin cetak tidak merusak layout */
        padding: 0.5cm; /* Margin halaman */
        box-sizing: border-box;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        position: relative;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        grid-template-rows: repeat(3, 1fr);
        gap: 0; /* Tidak ada gap antar kotak, border akan menjadi pembatas */
        height: 100%;
        width: 100%;
        border: 1px solid var(--border-color);
    }

    .photo {
        border-right: 1px dashed var(--border-color);
        border-bottom: 1px dashed var(--border-color);
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #fff;
    }

    /* Hapus border di tepi kanan dan bawah grid terakhir agar tidak double */
    .grid .photo:nth-child(3n) {
        border-right: none;
    }
    .grid .photo:nth-child(n+7) {
        border-bottom: none;
    }

    .photo img {
        width: 100%;
        height: 100%;
        object-fit: cover; /* Memastikan foto memenuhi kotak tanpa distorsi */
        display: block;
    }

    /* --- Toast Notification --- */
    .toast {
        position: fixed;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        background-color: #333;
        color: white;
        padding: 12px 24px;
        border-radius: 8px;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s, visibility 0.3s;
        z-index: 1000;
    }
    .toast.show {
        opacity: 1;
        visibility: visible;
    }

    /* Responsive untuk tampilan mobile screen */
    @media (max-width: 850px) {
        .page {
            /* Skala down untuk layar kecil */
            zoom: 0.5; 
        }
    }
</style>
</head>

<body>

<div class="controls">
    <h1>Layout Foto Studio A4 (3x3 Grid)</h1>
    <p>Unggah foto Anda, sistem akan mengaturnya 9 foto per halaman format A4 siap cetak.</p>
    
    <div class="input-group">
        <input type="file" id="upload" multiple accept="image/*">
        <button id="btnDownload" onclick="generatePDF()" disabled>
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
            Download PDF
        </button>
    </div>
</div>

<div id="preview">
    <div class="empty-state">Silakan pilih file foto untuk memulai...</div>
</div>

<!-- Toast Element -->
<div id="toast" class="toast">Memproses PDF...</div>

<script>
    const upload = document.getElementById("upload");
    const preview = document.getElementById("preview");
    const btnDownload = document.getElementById("btnDownload");
    const toast = document.getElementById("toast");

    // Fungsi untuk menampilkan pesan toast
    function showToast(message, duration = 3000) {
        toast.textContent = message;
        toast.classList.add("show");
        setTimeout(() => {
            toast.classList.remove("show");
        }, duration);
    }

    // Event Listener saat file dipilih
    upload.addEventListener("change", () => {
        const files = [...upload.files];
        
        if (files.length === 0) return;

        // Reset preview dan aktifkan tombol
        preview.innerHTML = "";
        btnDownload.disabled = false;
        
        const perPage = 9;
        const totalFiles = files.length;
        
        // Loop untuk setiap halaman
        for (let i = 0; i < totalFiles; i += perPage) {
            const page = document.createElement("div");
            page.className = "page";
            
            const grid = document.createElement("div");
            grid.className = "grid";

            // Ambil irisan file untuk halaman ini
            const pageFiles = files.slice(i, i + perPage);

            pageFiles.forEach(file => {
                const box = document.createElement("div");
                box.className = "photo";

                const img = document.createElement("img");
                const reader = new FileReader();
                
                reader.onload = e => {
                    img.src = e.target.result;
                    // Set atribut untuk memastikan dimensi
                    img.alt = "Uploaded Photo";
                };
                reader.readAsDataURL(file);

                box.appendChild(img);
                grid.appendChild(box);
            });

            // Opsional: Isi sisa kotak kosong jika file tidak genap (agar layout tetap rapi)
            // Jika ingin kotak kosong terlihat, Anda bisa menghapus blok kode ini.
            // Di sini kita biarkan kosong jika tidak ada foto.
            
            page.appendChild(grid);
            preview.appendChild(page);
        }
        
        showToast(`Berhasil memuat ${totalFiles} foto.`);
    });

    // Fungsi Generate PDF
    async function generatePDF() {
        const pages = document.querySelectorAll(".page");
        if (pages.length === 0) {
            showToast("Tidak ada halaman untuk diunduh.");
            return;
        }

        showToast("Sedang membuat PDF, mohon tunggu sebentar...");
        btnDownload.disabled = true;
        btnDownload.textContent = "Memproses...";

        try {
            const { jsPDF } = window.jspdf;
            // Buat instance PDF portrait, unit cm, format A4
            const pdf = new jsPDF("p", "cm", "a4");

            // Konfigurasi A4: 21cm x 29.7cm
            const pageWidth = 21;
            const pageHeight = 29.7;

            for (let i = 0; i < pages.length; i++) {
                // Gunakan scale: 2 atau 3 untuk resolusi lebih tajam
                // useCORS: true untuk gambar dari URL eksternal (jika ada)
                const canvas = await html2canvas(pages[i], { 
                    scale: 2, 
                    useCORS: true,
                    logging: false 
                });
                
                const imgData = canvas.toDataURL("image/jpeg", 0.95); // Kualitas 95%

                if (i > 0) {
                    pdf.addPage();
                }

                // Tambahkan gambar ke PDF (x, y, width, height)
                // Kita atur margin 0 di PDF karena margin sudah ditangani di CSS .page
                pdf.addImage(imgData, "JPEG", 0, 0, pageWidth, pageHeight);
            }

            pdf.save("layout-foto-studio.pdf");
            showToast("PDF berhasil diunduh!");

        } catch (error) {
            console.error(error);
            showToast("Terjadi kesalahan saat membuat PDF.");
        } finally {
            btnDownload.disabled = false;
            btnDownload.innerHTML = `<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg> Download PDF`;
        }
    }
</script>

</body>
</html>

